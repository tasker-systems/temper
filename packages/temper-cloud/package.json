{
  "name": "temper-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.api.json",
    "format": "biome format --write",
