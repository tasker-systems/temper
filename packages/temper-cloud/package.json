    "@node-saml/node-saml": "^5",
    "@vercel/blob": "^1",
    "jose": "^6",
    "onnxruntime-common": "^1.21.0",
    "onnxruntime-node": "^1.21.0",
    "pino": "^10.3.1",
    "uuidv7": "^1.2.1",
    "workflow": "^0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "onnxruntime-node": "1.21.0",
    "onnxruntime-common": "1.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^22",
    "docx": "^9.6.1",
    "pdf-lib": "^1.17.1",
