# temper-ui environment variables
#
# Copy to `.env` for local development. The .env file is gitignored.
# For production, set these in the Vercel project dashboard.
#
# `bun run dev` and `bun run check` both fail to start without these set.

# ---------------------------------------------------------------------------
# API connectivity
# ---------------------------------------------------------------------------

# Base URL for server-side calls from SvelteKit loaders to the temper-api.
# In dev: point at a locally-running Axum server (default port 3000).
# In prod: empty string (same-origin via vercel.json /api/* rewrite) or the
#          full temper-cloud deployment URL.
API_BASE_URL=http://localhost:3000

# Public origin of this UI app. Used to construct the Auth0 redirect_uri
# (`${APP_URL}/auth/callback`) and the post-logout returnTo URL.
# Note: NOT prefixed with PUBLIC_ — that prefix is reserved by SvelteKit
# for `$env/static/public` (client-bundle-visible) variables.
APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Storefront (public marketing route group)
# ---------------------------------------------------------------------------

# The `(public)` route group (landing, manifesto, theory, cognitive-maps,
# operating) is the marketing storefront for the canonical temperkb.io
# deployment. It is ON by default. App-only self-hosted installs disable it
# by setting this to a falsy token (false/0/off/no); every (public) route then
# redirects to /auth/login (the app entrypoint). Leave unset to keep it on.
# STOREFRONT_ENABLED=false

# ---------------------------------------------------------------------------
# Database (Neon-direct queries — read-only nav chrome only)
# ---------------------------------------------------------------------------

# Same Neon connection string the temper-api uses. Server loaders that
# bypass the API for navigation chrome connect through `lib/server/db.ts`.
DATABASE_URL=postgresql://temper:temper@localhost:5437/temper_development

# ---------------------------------------------------------------------------
# Auth0 (temper-web Regular Web Application)
# ---------------------------------------------------------------------------
#
# The `temper-web` application in the `temperkb.us.auth0.com` tenant must be
# configured as a Regular Web Application (NOT a SPA) with:
#   - Allowed Callback URLs: http://localhost:5173/auth/callback,
#                            https://temperkb.io/auth/callback
#   - Allowed Logout URLs:   http://localhost:5173,
#                            https://temperkb.io
#   - Allowed Web Origins:   http://localhost:5173,
#                            https://temperkb.io

AUTH0_DOMAIN=temperkb.us.auth0.com
AUTH0_CLIENT_ID=replace-with-client-id-from-auth0-dashboard
AUTH0_CLIENT_SECRET=replace-with-client-secret-from-auth0-dashboard
AUTH0_AUDIENCE=https://temperkb.io/api

# ---------------------------------------------------------------------------
# Session cookie encryption
# ---------------------------------------------------------------------------

# Secret used to derive the AES-256-GCM key for the JWE session cookie.
# Generate with: `openssl rand -base64 32`
# Rotating this value invalidates all live sessions.
SESSION_SECRET=replace-with-32-bytes-of-random-base64
