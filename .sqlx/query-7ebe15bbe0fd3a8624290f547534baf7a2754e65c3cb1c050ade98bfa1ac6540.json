  "query": "SELECT tm.profile_id,\n                  p.handle,\n                  tm.role AS \"role: TeamRole\",\n                  tm.source AS \"source: TeamMemberSource\"\n             FROM kb_team_members tm\n             JOIN kb_profiles p ON p.id = tm.profile_id\n            WHERE tm.team_id = $1\n            ORDER BY tm.role, p.handle",
