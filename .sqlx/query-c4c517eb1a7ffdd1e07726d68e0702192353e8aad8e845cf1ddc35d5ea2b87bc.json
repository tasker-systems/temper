  "query": "\n        SELECT asserted_by_event_id AS \"correlation_id!: Uuid\",\n               is_folded            AS \"is_folded!\"\n          FROM kb_resource_edges\n         WHERE source_resource_id = $1\n           AND target_resource_id = $2\n           AND edge_kind          = $3\n           AND label              = $4\n           AND polarity           = $5\n         LIMIT 1\n        ",
