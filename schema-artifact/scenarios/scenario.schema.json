{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "cogmap": {
      "$ref": "#/$defs/CogmapDef"
    },
    "world": {
      "$ref": "#/$defs/WorldDef"
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ResourceDef"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EdgeDef"
      }
    },
    "uses_lenses": {
      "description": "Names of (system-seeded) lenses this scenario uses; validated up front.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Step"
      }
    }
  },
  "required": [
    "name",
    "cogmap",
    "world",
    "resources",
    "uses_lenses",
    "steps"
  ],
  "$defs": {
    "CogmapDef": {
      "type": "object",
      "properties": {
        "telos": {
          "$ref": "#/$defs/TelosDef"
        },
        "owner": {
          "description": "profile handle (declared in `world.profiles`)",
          "type": "string"
        },
        "emitter": {
          "description": "entity name (declared in `world.entities`)",
          "type": "string"
        }
      },
      "required": [
        "telos",
        "owner",
        "emitter"
      ]
    },
    "TelosDef": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "title",
        "statement"
      ]
    },
    "WorldDef": {
      "type": "object",
      "properties": {
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProfileDef"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDef"
          }
        }
      },
      "required": [
        "profiles",
        "entities"
      ]
    },
    "ProfileDef": {
      "type": "object",
      "properties": {
        "handle": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "system_access": {
          "description": "'none' | 'approved' | 'admin'",
          "type": "string"
        }
      },
      "required": [
        "handle",
        "display_name",
        "system_access"
      ]
    },
    "EntityDef": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "profile": {
          "description": "profile handle",
          "type": "string"
        }
      },
      "required": [
        "name",
        "profile"
      ]
    },
    "ResourceDef": {
      "type": "object",
      "properties": {
        "key": {
          "description": "local stable id — edges/asserts reference this",
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "origin_uri": {
          "type": "string"
        },
        "home": {
          "type": "string",
          "default": "cogmap"
        },
        "doc_type": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "body": {
          "type": "string"
        },
        "facets": {
          "anyOf": [
            {
              "$ref": "#/$defs/FacetDef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "key",
        "origin_uri",
        "body"
      ]
    },
    "FacetDef": {
      "description": "One `property_key='facet'` row per resource. `values` is the coherent multi-key JSONB object\n(scalar or array values); `weight` applies to every `(path,value)` pair it expands to. A bare map\nis sugar: `facets: { phase: x }` == `{ values: { phase: x }, weight: 1.0 }`.",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "values": {
              "type": "object",
              "additionalProperties": true
            },
            "weight": {
              "type": "number",
              "format": "double",
              "default": 1.0
            }
          },
          "required": [
            "values"
          ]
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "EdgeDef": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EdgeKind"
        },
        "label": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "weight": {
          "type": "number",
          "format": "double",
          "default": 1.0
        }
      },
      "required": [
        "from",
        "to",
        "kind"
      ]
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "express",
        "contains",
        "leads_to",
        "near"
      ]
    },
    "Step": {
      "description": "Internally tagged by `do:` — serde_yaml 0.9 rejects the externally-tagged single-key-map form\n(it wants `!Variant` tags), so the runbook discriminates on a `do` field.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "do": {
              "type": "string",
              "const": "materialize"
            }
          },
          "required": [
            "do",
            "lens"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "edges": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/EdgeDef"
              }
            },
            "do": {
              "type": "string",
              "const": "emit_event"
            }
          },
          "required": [
            "do",
            "type",
            "edges"
          ]
        },
        {
          "type": "object",
          "properties": {
            "checks": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Expectation"
              }
            },
            "do": {
              "type": "string",
              "const": "assert"
            }
          },
          "required": [
            "do",
            "checks"
          ]
        }
      ]
    },
    "Expectation": {
      "description": "Internally tagged by `check:` (same serde_yaml constraint as `Step`).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "op": {
              "$ref": "#/$defs/CmpOp"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            },
            "check": {
              "type": "string",
              "const": "region_count"
            }
          },
          "required": [
            "check",
            "lens",
            "op",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "members": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "co_region"
            }
          },
          "required": [
            "check",
            "lens",
            "members",
            "expect"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "greater": {
              "type": "string"
            },
            "lesser": {
              "type": "string"
            },
            "check": {
              "type": "string",
              "const": "cohesion_order"
            }
          },
          "required": [
            "check",
            "lens",
            "greater",
            "lesser"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "member": {
              "type": "string"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            },
            "check": {
              "type": "string",
              "const": "region_size"
            }
          },
          "required": [
            "check",
            "lens",
            "member",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "member": {
              "type": "string"
            },
            "op": {
              "$ref": "#/$defs/CmpOp"
            },
            "value": {
              "type": "number",
              "format": "double"
            },
            "check": {
              "type": "string",
              "const": "internal_tension"
            }
          },
          "required": [
            "check",
            "lens",
            "member",
            "op",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens": {
              "type": "string"
            },
            "check": {
              "type": "string",
              "const": "reproducible"
            }
          },
          "required": [
            "check",
            "lens"
          ]
        },
        {
          "type": "object",
          "properties": {
            "lens_a": {
              "type": "string"
            },
            "lens_b": {
              "type": "string"
            },
            "check": {
              "type": "string",
              "const": "fingerprint_differs"
            }
          },
          "required": [
            "check",
            "lens_a",
            "lens_b"
          ]
        },
        {
          "type": "object",
          "properties": {
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "stale"
            }
          },
          "required": [
            "check",
            "expect"
          ]
        }
      ]
    },
    "CmpOp": {
      "type": "string",
      "enum": [
        ">=",
        ">",
        "=="
      ]
    }
  }
}
