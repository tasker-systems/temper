{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelationshipCorrected",
  "type": "object",
  "properties": {
    "edge_id": {
      "$ref": "#/$defs/EdgeId"
    },
    "scar": {
      "description": "Structured account of the wrongness — the scar (production's shape).",
      "type": "string"
    }
  },
  "required": [
    "edge_id",
    "scar"
  ],
  "$defs": {
    "EdgeId": {
      "description": "A `kb_edges` row (a declared relationship assertion).",
      "type": "string",
      "format": "uuid"
    }
  }
}
