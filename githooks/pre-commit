#!/usr/bin/env bash
set -euo pipefail

echo "==> Running pre-commit checks..."

echo "  Checking formatting..."
cargo fmt --all -- --check
echo "  ✓ Formatting OK"

echo "  Running Clippy..."
# SQLX_OFFLINE: --all-features pulls temper-next's query! macros, which resolve
# against the `temper_next` namespace, not the dev DB's default `public`
# search_path — live validation collapses to E0282. Use the committed .sqlx
# caches instead (matches CI's code-quality job and all `cargo make` tasks).
SQLX_OFFLINE=true cargo clippy --all-targets --all-features -- -D warnings
echo "  ✓ Clippy OK"

echo "  Checking docs..."
SQLX_OFFLINE=true RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps --document-private-items --quiet
echo "  ✓ Docs OK"

# TypeScript checks (packages/temper-cloud)
echo "  TypeScript typecheck..."
(cd packages/temper-cloud && bun run typecheck)
echo "  ✓ TypeScript OK"

echo "  Biome lint & format..."
(cd packages/temper-cloud && bun run check)
echo "  ✓ Biome OK"

echo "==> All pre-commit checks passed."
