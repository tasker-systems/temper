#!/usr/bin/env bash
set -euo pipefail

echo "==> Running pre-commit checks..."

echo "  Checking formatting..."
cargo fmt --all -- --check
echo "  ✓ Formatting OK"

echo "  Running Clippy..."
# SQLX_OFFLINE: --all-features pulls temper-next's query! macros, which resolve
# against the `temper_next` namespace, not the dev DB's default `public`
# search_path — live validation collapses to E0282. Use the committed .sqlx
# caches instead (matches CI's code-quality job and all `cargo make` tasks).
SQLX_OFFLINE=true cargo clippy --all-targets --all-features -- -D warnings
echo "  ✓ Clippy OK"

echo "  Checking docs..."
SQLX_OFFLINE=true RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps --document-private-items --quiet
echo "  ✓ Docs OK"

# openapi.json is a committed product of the Axum router, so it goes stale from a new route OR from a
# new field on any schema type reachable from one. Nothing else in this hook notices. Cheap here:
# clippy above already compiled temper-api, so this is just running the emit-openapi bin.
# Output is captured and replayed only on failure — check-openapi-spec.sh prints the offending diff.
echo "  Checking OpenAPI spec..."
REPO_ROOT="$(git rev-parse --show-toplevel)"
for openapi_gate in check-openapi-spec.sh check-openapi-routes.sh; do
  if ! openapi_out=$(SQLX_OFFLINE=true bash "$REPO_ROOT/.github/scripts/$openapi_gate" 2>&1); then
    echo "$openapi_out" >&2
    echo "  ✗ OpenAPI check failed ($openapi_gate) — run: cargo make openapi" >&2
    exit 1
  fi
done
echo "  ✓ OpenAPI OK"

# TypeScript checks (packages/temper-cloud)
echo "  TypeScript typecheck..."
(cd packages/temper-cloud && bun run typecheck)
echo "  ✓ TypeScript OK"

echo "  Biome lint & format..."
(cd packages/temper-cloud && bun run check)
echo "  ✓ Biome OK"

echo "==> All pre-commit checks passed."
