target/
*.swp
*.swo
.DS_Store
.superpowers/
# Track only the shared team config (`.claude/settings.json`) — per-user
# state (settings.local.json, project memory, caches) stays ignored.
# Uses `.claude/*` rather than `.claude/` so the negation below can re-include.
.claude/*
!.claude/settings.json
# Shared, committed multi-agent workflows (resolvable by name at runtime).
!.claude/workflows/
.env
.vercel
node_modules
.neon
.logs
.env*
tmp/

# ts-rs writes here when TS_RS_EXPORT_DIR is unset (i.e. any bare `cargo test -p temper-core
# --all-features`, which enables the `typescript` feature). The authoritative output lives in
# packages/temper-ui/src/lib/types/generated/, written by `cargo make generate-ts-types`.
crates/*/bindings/
