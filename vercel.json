{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd packages/temper-cloud && bun install",
  "build": {
    "env": {
      "SQLX_OFFLINE": "true"
    }
  },
  "crons": [
    { "path": "/api/embed/dispatch?shard=0", "schedule": "* * * * *" },
    { "path": "/api/embed/dispatch?shard=1", "schedule": "* * * * *" },
    { "path": "/api/embed/dispatch?shard=2", "schedule": "* * * * *" },
    { "path": "/api/embed/dispatch?shard=3", "schedule": "* * * * *" },
    { "path": "/api/embed/warm", "schedule": "*/2 * * * *" },
    { "path": "/api/slack/intents/reap", "schedule": "0 * * * *" }
  ],
  "functions": {
    "api/axum.rs": { "memory": 3009, "maxDuration": 60 },
    "api/mcp.rs": { "memory": 3009, "maxDuration": 60 },
    "api/internal.rs": { "memory": 3009, "maxDuration": 300 }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/mcp", "dest": "/api/mcp" },
    { "src": "/mcp/(.*)", "dest": "/api/mcp" },
    { "src": "/api/embed/dispatch", "dest": "/api/internal" },
    { "src": "/api/embed/warm", "dest": "/api/internal" },
    { "src": "/api/slack/intents/reap", "dest": "/api/internal" },
    { "src": "/internal/(.*)", "dest": "/api/internal" },
    { "src": "/.well-known/oauth-authorization-server", "dest": "/api/oauth/authorization-server" },
    { "src": "/oauth/jwks", "dest": "/api/oauth/jwks" },
    { "src": "/oauth/authorize", "dest": "/api/oauth/authorize" },
    { "src": "/oauth/saml/login", "dest": "/api/oauth/saml/login" },
    { "src": "/oauth/saml/acs", "dest": "/api/oauth/saml/acs" },
    { "src": "/oauth/saml/metadata", "dest": "/api/oauth/saml/metadata" },
    { "src": "/oauth/token", "dest": "/api/oauth/token" },
    { "src": "/oauth/(.*)", "dest": "/api/mcp" },
    { "src": "/.well-known/(.*)", "dest": "/api/mcp" },
    { "src": "/(.*)", "dest": "/api/axum" }
  ]
}
