{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd packages/temper-cloud && bun install",
  "fluid": true,
  "routes": [
    { "src": "/api/auth-login", "dest": "/api/auth-login" },
    { "src": "/api/auth-callback", "dest": "/api/auth-callback" },
    { "src": "/api/upload", "dest": "/api/upload" },
    { "src": "/(.*)", "dest": "/api/axum" }
  ]
}
