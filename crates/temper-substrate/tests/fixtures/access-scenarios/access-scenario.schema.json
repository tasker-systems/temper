{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccessScenario",
  "description": "The access-scenario document (`tests/fixtures/access-scenarios/*.yaml`): a full access world plus\nthe inline checks that assert it.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "world": {
      "$ref": "#/$defs/AccessWorld"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AccessCheck"
      }
    }
  },
  "required": [
    "name",
    "world",
    "checks"
  ],
  "$defs": {
    "AccessWorld": {
      "description": "The access topology. `profiles`/`entities` reuse the charter model's defs.",
      "type": "object",
      "properties": {
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProfileDef"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDef"
          }
        },
        "teams": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TeamDef"
          }
        },
        "memberships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MembershipDef"
          }
        },
        "contexts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextDef"
          }
        },
        "context_shares": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContextShareDef"
          }
        },
        "cogmaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AccessCogmapDef"
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AccessResourceDef"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AccessEdgeDef"
          }
        }
      },
      "required": [
        "profiles",
        "entities",
        "teams",
        "cogmaps",
        "resources"
      ]
    },
    "ProfileDef": {
      "type": "object",
      "properties": {
        "handle": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "system_access": {
          "description": "'none' | 'approved' | 'admin'",
          "type": "string"
        }
      },
      "required": [
        "handle",
        "display_name",
        "system_access"
      ]
    },
    "EntityDef": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "profile": {
          "description": "profile handle",
          "type": "string"
        }
      },
      "required": [
        "name",
        "profile"
      ]
    },
    "TeamDef": {
      "description": "A team. `parents` are slugs in this same `teams` list (the down-only DAG, `kb_teams_parents`).",
      "type": "object",
      "properties": {
        "slug": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "parents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "slug",
        "name"
      ]
    },
    "MembershipDef": {
      "description": "A sub-team membership. Root (`temper-system`) joins are maintained by the `sync_system_membership`\ntrigger from `system_access`, so they are NOT listed here.",
      "type": "object",
      "properties": {
        "team": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      },
      "required": [
        "team",
        "profile",
        "role"
      ]
    },
    "ContextDef": {
      "description": "A named context — a real owner-scoped `kb_contexts` row (WS6 §2 amendment), the referent for named\nhomes and shares. Exactly one of `owner_profile` (a `world` profile handle) / `owner_team` (a\n`world` team slug) must be set — the loader validates this and derives `slug = slugify(name)`.\nOwner is purely namespace-scoping (which owner the slug is unique within); reachability is still\ngoverned by `context_shares` (`kb_team_contexts`), orthogonal to owner.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "owner_profile": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "owner_team": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ]
    },
    "ContextShareDef": {
      "description": "A context-share (`kb_team_contexts`): the team's vis-reach includes the context's\nresources and context-homed edges (WS6 adjudication §2). `team` may name a\ntrigger-created personal team (`personal-<handle>`) — the loader refreshes its\nteam map from the DB after profiles load.",
      "type": "object",
      "properties": {
        "context": {
          "type": "string"
        },
        "team": {
          "type": "string"
        }
      },
      "required": [
        "context",
        "team"
      ]
    },
    "AccessCogmapDef": {
      "description": "A cogmap. Bare producer maps carry only `name` + `teams`. A `telos` (charter) makes it a genesis\nmap (needs `owner` + `emitter`); the loader runs `cogmap_genesis` for it.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "teams": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "owner": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "emitter": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "telos": {
          "anyOf": [
            {
              "$ref": "#/$defs/TelosDef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "TelosDef": {
      "description": "The telos charter as real content-blocks (domain-B §1, content-block-primitive β): block-0 is the\n`statement`, blocks 1..n are the `questions` (each `question + \"\\n\\n\" + context`), then `framing`\nblocks situate the telos. Each block's kind is stamped as a `block_role` property\n(`statement`/`question`/`framing`) by the persist path — see `block_specs`. The loader\nturns this into an ordered prose list for `content::prepare_blocks`.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/QuestionDef"
          }
        },
        "framing": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "title",
        "statement"
      ]
    },
    "QuestionDef": {
      "description": "A guiding question with its situating context. `context` defaults empty so a bare\n`{ question: ... }` is valid; a rich question-with-context naturally chunks into >1 window.",
      "type": "object",
      "properties": {
        "question": {
          "type": "string"
        },
        "context": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "question"
      ]
    },
    "AccessResourceDef": {
      "description": "A resource: identity + a single home (context or cogmap) + explicit capability grants.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "origin_uri": {
          "type": "string"
        },
        "home": {
          "$ref": "#/$defs/HomeDef"
        },
        "owner": {
          "type": "string"
        },
        "grants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GrantDef"
          }
        }
      },
      "required": [
        "key",
        "title",
        "origin_uri",
        "home",
        "owner"
      ]
    },
    "HomeDef": {
      "description": "The resource home anchor. `{ anchor: cogmap, name: <cogmap> }`, `{ anchor: context, name: <context> }`\n(a real `kb_contexts` row from `world.contexts` — shareable via `context_shares`), or the anonymous\n`{ anchor: context }` (a synthetic generated-uuid anchor with no row — an unshared workspace).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "anchor": {
              "type": "string",
              "const": "cogmap"
            }
          },
          "required": [
            "anchor",
            "name"
          ]
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "anchor": {
              "type": "string",
              "const": "context"
            }
          },
          "required": [
            "anchor"
          ]
        }
      ]
    },
    "GrantDef": {
      "description": "A capability grant (`kb_resource_access`). `to` is a team or profile anchor. Caps default false; the\nDB CHECK enforces `write|delete|grant ⇒ read`.",
      "type": "object",
      "properties": {
        "to": {
          "$ref": "#/$defs/GrantAnchor"
        },
        "can_read": {
          "type": "boolean",
          "default": false
        },
        "can_write": {
          "type": "boolean",
          "default": false
        },
        "can_delete": {
          "type": "boolean",
          "default": false
        },
        "can_grant": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "to"
      ]
    },
    "GrantAnchor": {
      "description": "A grant anchor — `{ anchor: team, slug: <slug> }` or `{ anchor: profile, handle: <handle> }`.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "anchor": {
              "type": "string",
              "const": "team"
            }
          },
          "required": [
            "anchor",
            "slug"
          ]
        },
        {
          "type": "object",
          "properties": {
            "handle": {
              "type": "string"
            },
            "anchor": {
              "type": "string",
              "const": "profile"
            }
          },
          "required": [
            "anchor",
            "handle"
          ]
        }
      ]
    },
    "AccessEdgeDef": {
      "description": "An authored edge homed in a named cogmap, fired through `relationship_assert` (the event-backed path\n— `kb_edges` carries NOT-NULL event FKs). `from`/`to` are resource keys.",
      "type": "object",
      "properties": {
        "key": {
          "description": "Unique handle for this edge within the scenario. `edge_visible_to` checks resolve through it\n(the captured `kb_edges.id`), NOT through `label` — `label` is a decorative, non-unique TEXT\ncolumn, so keying a lookup on it silently matches the wrong row when two edges share a label.",
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EdgeKind"
        },
        "label": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "weight": {
          "type": "number",
          "format": "double",
          "default": 1.0
        },
        "home": {
          "$ref": "#/$defs/EdgeHomeDef"
        },
        "emitter": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "from",
        "to",
        "kind",
        "home",
        "emitter"
      ]
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "express",
        "contains",
        "leads_to",
        "near"
      ]
    },
    "EdgeHomeDef": {
      "description": "An edge home anchor — `{ anchor: cogmap, name: .. }` or `{ anchor: context, name: .. }` (a named\ncontext from `world.contexts`; context-homed edges gate by context-share, WS6 adjudication §2).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "anchor": {
              "type": "string",
              "const": "cogmap"
            }
          },
          "required": [
            "anchor",
            "name"
          ]
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "anchor": {
              "type": "string",
              "const": "context"
            }
          },
          "required": [
            "anchor",
            "name"
          ]
        }
      ]
    },
    "AccessCheck": {
      "description": "One access assertion. Internally tagged by `check:` (same serde_yaml constraint as the charter\n`Expectation`). Each variant resolves its named referents and calls one gate function.",
      "oneOf": [
        {
          "description": "S1 — consumer reach: `resources_visible_to(profile)` ∋ resource.",
          "type": "object",
          "properties": {
            "profile": {
              "type": "string"
            },
            "resource": {
              "type": "string"
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "visible_to"
            }
          },
          "required": [
            "check",
            "profile",
            "resource",
            "expect"
          ]
        },
        {
          "description": "S2 — producer intersection / leak-safety: `resources_accessible_to_cogmap(cogmap)` ∋ resource.",
          "type": "object",
          "properties": {
            "cogmap": {
              "type": "string"
            },
            "resource": {
              "type": "string"
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "producer_reach"
            }
          },
          "required": [
            "check",
            "cogmap",
            "resource",
            "expect"
          ]
        },
        {
          "description": "S3 — edge-home protection: `edges_visible_to(profile)` ∋ edge (resolved by the edge's `key`,\nits captured `kb_edges.id` — NOT by the non-unique `label`).",
          "type": "object",
          "properties": {
            "profile": {
              "type": "string"
            },
            "edge": {
              "description": "The target edge's `key` (see [`AccessEdgeDef::key`]).",
              "type": "string"
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "edge_visible_to"
            }
          },
          "required": [
            "check",
            "profile",
            "edge",
            "expect"
          ]
        },
        {
          "description": "S5 — delegation priming: `cogmaps_share_a_team(a, b)`.",
          "type": "object",
          "properties": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "string"
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "cogmaps_share_team"
            }
          },
          "required": [
            "check",
            "a",
            "b",
            "expect"
          ]
        },
        {
          "description": "S4 — charter-block gating: `count(resource_blocks(cogmap_telos(cogmap), 'profile', profile, NULL))`.",
          "type": "object",
          "properties": {
            "cogmap": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "expect_count": {
              "type": "integer",
              "format": "int64"
            },
            "check": {
              "type": "string",
              "const": "charter_blocks_visible"
            }
          },
          "required": [
            "check",
            "cogmap",
            "profile",
            "expect_count"
          ]
        },
        {
          "description": "S6 — write axis (WS2): `can_modify_resource(profile, resource)`. Owner/originator or an explicit\nWRITE grant ⇒ true; a context-share reader (read-reach only) or a no-access profile ⇒ false.",
          "type": "object",
          "properties": {
            "profile": {
              "type": "string"
            },
            "resource": {
              "type": "string"
            },
            "expect": {
              "type": "boolean"
            },
            "check": {
              "type": "string",
              "const": "can_modify"
            }
          },
          "required": [
            "check",
            "profile",
            "resource",
            "expect"
          ]
        }
      ]
    }
  }
}
