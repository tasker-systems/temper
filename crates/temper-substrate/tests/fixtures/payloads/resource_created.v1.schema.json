{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResourceCreated",
  "type": "object",
  "properties": {
    "resource_id": {
      "$ref": "#/$defs/ResourceId"
    },
    "title": {
      "type": "string"
    },
    "origin_uri": {
      "type": "string"
    },
    "home": {
      "$ref": "#/$defs/AnchorRef"
    },
    "owner_profile_id": {
      "$ref": "#/$defs/ProfileId"
    },
    "originator_profile_id": {
      "description": "The home's originator (§2: \"carrying its current originator/owner\"). Absent ⇒ the projector\nCOALESCEs it to `owner_profile_id` (the scenario path, where originator≡owner). Synthesis sets\nit explicitly so a production row whose originator differs from its owner survives the carry.",
      "anyOf": [
        {
          "$ref": "#/$defs/ProfileId"
        },
        {
          "type": "null"
        }
      ]
    },
    "doc_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/BlockManifest"
      }
    }
  },
  "required": [
    "resource_id",
    "title",
    "origin_uri",
    "home",
    "owner_profile_id",
    "blocks"
  ],
  "$defs": {
    "ResourceId": {
      "description": "A `kb_resources.id` value.",
      "type": "string",
      "format": "uuid"
    },
    "AnchorRef": {
      "type": "object",
      "properties": {
        "table": {
          "$ref": "#/$defs/AnchorTable"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "table",
        "id"
      ]
    },
    "AnchorTable": {
      "description": "A polymorphic anchor/endpoint reference. Serializes table names exactly as the DDL spells them.",
      "type": "string",
      "enum": [
        "kb_contexts",
        "kb_cogmaps",
        "kb_resources",
        "kb_edges",
        "kb_content_blocks",
        "kb_teams",
        "kb_profiles"
      ]
    },
    "ProfileId": {
      "description": "A `kb_profiles.id` value.",
      "type": "string",
      "format": "uuid"
    },
    "BlockManifest": {
      "description": "One block's manifest. `block_body_hash` deliberately absent — it is sha256(ordered chunk hashes),\nderived in the projector (the derived-state rule applied to the spec's own §3 sketch).",
      "type": "object",
      "properties": {
        "block_id": {
          "$ref": "#/$defs/BlockId"
        },
        "seq": {
          "type": "integer",
          "format": "int32"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "chunks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChunkManifest"
          }
        },
        "incorporated": {
          "description": "The ordered sources this block's content was incorporated from — recorded into\n`kb_block_provenance` by the projector. Empty (and skipped on the wire) for the\nscenario/charter paths; set by the resource create/update write path from the caller's sources.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Incorporation"
          }
        }
      },
      "required": [
        "block_id",
        "seq",
        "chunks"
      ]
    },
    "BlockId": {
      "description": "A `kb_content_blocks.id` value — a resource's addressable interior unit.",
      "type": "string",
      "format": "uuid"
    },
    "ChunkManifest": {
      "description": "Content-addressed chunk reference: structure + hash, NEVER prose (CAS rule, spec §0.1).",
      "type": "object",
      "properties": {
        "chunk_id": {
          "$ref": "#/$defs/ChunkId"
        },
        "chunk_index": {
          "type": "integer",
          "format": "int32"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "required": [
        "chunk_id",
        "chunk_index",
        "content_hash"
      ]
    },
    "ChunkId": {
      "description": "A `kb_chunks.id` value — one embedding window of a block's prose.",
      "type": "string",
      "format": "uuid"
    },
    "Incorporation": {
      "type": "object",
      "properties": {
        "source": {
          "$ref": "#/$defs/ProvenanceSource"
        },
        "seq": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "source",
        "seq"
      ]
    },
    "ProvenanceSource": {
      "description": "Tagged like the DDL's provenance_source_kind ({kind, value} sum — content-block spec).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "event"
            },
            "value": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "resource"
            },
            "value": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "description": "An external URL (e.g. a Linear issue, a GitHub PR, a doc). The value is the URL as supplied;\nthe projector normalizes + resolves it to a `kb_remote_sources.id` via `_upsert_remote_source`.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "remote"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        }
      ]
    }
  }
}
