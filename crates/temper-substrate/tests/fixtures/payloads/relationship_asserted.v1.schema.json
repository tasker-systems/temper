{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelationshipAsserted",
  "type": "object",
  "properties": {
    "edge_id": {
      "$ref": "#/$defs/EdgeId"
    },
    "edge_kind": {
      "$ref": "#/$defs/EdgeKind"
    },
    "home": {
      "$ref": "#/$defs/AnchorRef"
    },
    "label": {
      "type": [
        "string",
        "null"
      ]
    },
    "polarity": {
      "$ref": "#/$defs/EdgePolarity",
      "default": "forward"
    },
    "source": {
      "$ref": "#/$defs/AnchorRef"
    },
    "target": {
      "$ref": "#/$defs/AnchorRef"
    },
    "weight": {
      "type": "number",
      "format": "double"
    }
  },
  "required": [
    "edge_id",
    "source",
    "target",
    "edge_kind",
    "weight",
    "home"
  ],
  "$defs": {
    "AnchorRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "table": {
          "$ref": "#/$defs/AnchorTable"
        }
      },
      "required": [
        "table",
        "id"
      ]
    },
    "AnchorTable": {
      "description": "A polymorphic anchor/endpoint reference. Serializes table names exactly as the DDL spells them.",
      "type": "string",
      "enum": [
        "kb_contexts",
        "kb_cogmaps",
        "kb_resources",
        "kb_edges",
        "kb_content_blocks",
        "kb_teams",
        "kb_profiles"
      ]
    },
    "EdgeId": {
      "description": "A `kb_edges.id` value — a declared relationship assertion.\n\nReturned by `Backend::assert_relationship` and fed back into\nretype/reweight/fold. Post-WS6-flip there is a single substrate-backed\nbackend, so this is always a real `kb_edges` row id (not a backend-opaque\ncorrelation handle).",
      "type": "string",
      "format": "uuid"
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "express",
        "contains",
        "leads_to",
        "near"
      ]
    },
    "EdgePolarity": {
      "description": "kb_edges.polarity. The projection's only non-parameter column today — carried explicitly so the\npayload covers every projected column (spec §9 column-coverage obligation).",
      "type": "string",
      "enum": [
        "forward",
        "inverse"
      ]
    }
  }
}
