{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario",
  "description": "The scenario document (`tests/fixtures/scenarios/*.yaml`): a seed reference (or embed) plus the\nordered `steps` runbook.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "seed": {
      "$ref": "#/$defs/SeedRef"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Step"
      }
    }
  },
  "required": [
    "name",
    "seed",
    "steps"
  ],
  "$defs": {
    "CmpOp": {
      "type": "string",
      "enum": [
        ">=",
        ">",
        "=="
      ]
    },
    "CogmapDef": {
      "type": "object",
      "properties": {
        "emitter": {
          "description": "entity name (declared in `world.entities`)",
          "type": "string"
        },
        "owner": {
          "description": "profile handle (declared in `world.profiles`)",
          "type": "string"
        },
        "telos": {
          "$ref": "#/$defs/TelosDef"
        }
      },
      "required": [
        "telos",
        "owner",
        "emitter"
      ]
    },
    "DriftTierName": {
      "description": "The drift tier names as they appear in scenario YAML (`check: drift_tier, tier: readout`).",
      "type": "string",
      "enum": [
        "fresh",
        "readout",
        "structural"
      ]
    },
    "EdgeDef": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EdgeKind"
        },
        "label": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "to": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "format": "double",
          "default": 1.0
        }
      },
      "required": [
        "from",
        "to",
        "kind"
      ]
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "express",
        "contains",
        "leads_to",
        "near"
      ]
    },
    "EntityDef": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "profile": {
          "description": "profile handle",
          "type": "string"
        }
      },
      "required": [
        "name",
        "profile"
      ]
    },
    "Expectation": {
      "description": "Internally tagged by `check:` (same serde_yaml constraint as `Step`).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "region_count"
            },
            "lens": {
              "type": "string"
            },
            "op": {
              "$ref": "#/$defs/CmpOp"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "required": [
            "check",
            "lens",
            "op",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "co_region"
            },
            "expect": {
              "type": "boolean"
            },
            "lens": {
              "type": "string"
            },
            "members": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "check",
            "lens",
            "members",
            "expect"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "cohesion_order"
            },
            "greater": {
              "type": "string"
            },
            "lens": {
              "type": "string"
            },
            "lesser": {
              "type": "string"
            }
          },
          "required": [
            "check",
            "lens",
            "greater",
            "lesser"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "region_size"
            },
            "lens": {
              "type": "string"
            },
            "member": {
              "type": "string"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "required": [
            "check",
            "lens",
            "member",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "internal_tension"
            },
            "lens": {
              "type": "string"
            },
            "member": {
              "type": "string"
            },
            "op": {
              "$ref": "#/$defs/CmpOp"
            },
            "value": {
              "type": "number",
              "format": "double"
            }
          },
          "required": [
            "check",
            "lens",
            "member",
            "op",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "reproducible"
            },
            "lens": {
              "type": "string"
            }
          },
          "required": [
            "check",
            "lens"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "fingerprint_differs"
            },
            "lens_a": {
              "type": "string"
            },
            "lens_b": {
              "type": "string"
            }
          },
          "required": [
            "check",
            "lens_a",
            "lens_b"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "stale"
            },
            "expect": {
              "type": "boolean"
            }
          },
          "required": [
            "check",
            "expect"
          ]
        },
        {
          "type": "object",
          "properties": {
            "check": {
              "type": "string",
              "const": "drift_tier"
            },
            "lens": {
              "type": "string"
            },
            "tier": {
              "$ref": "#/$defs/DriftTierName"
            }
          },
          "required": [
            "check",
            "lens",
            "tier"
          ]
        }
      ]
    },
    "FacetDef": {
      "description": "One `property_key='facet'` row per resource. `values` is the coherent multi-key JSONB object\n(scalar or array values); `weight` applies to every `(path,value)` pair it expands to. A bare map\nis sugar: `facets: { phase: x }` == `{ values: { phase: x }, weight: 1.0 }`.",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "values": {
              "type": "object",
              "additionalProperties": true
            },
            "weight": {
              "type": "number",
              "format": "double",
              "default": 1.0
            }
          },
          "required": [
            "values"
          ]
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "ProfileDef": {
      "type": "object",
      "properties": {
        "display_name": {
          "type": "string"
        },
        "handle": {
          "type": "string"
        },
        "system_access": {
          "$ref": "#/$defs/SystemAccess"
        }
      },
      "required": [
        "handle",
        "display_name",
        "system_access"
      ]
    },
    "QuestionDef": {
      "description": "A guiding question with its situating context. `context` defaults empty so a bare\n`{ question: ... }` is valid; a rich question-with-context naturally chunks into >1 window.",
      "type": "object",
      "properties": {
        "context": {
          "type": "string",
          "default": ""
        },
        "question": {
          "type": "string"
        }
      },
      "required": [
        "question"
      ]
    },
    "ResourceDef": {
      "description": "A seed resource. It has no `home` selector: a seed instantiates a *cogmap*, and every resource it\ndeclares is homed in that cogmap by construction (`loader::load_resources`). Contexts are never\nseeded — a context accretes from real work and its telos is *derived* from that activity — so\nthere is nothing here to choose between. (The sibling access DSL does have a real `HomeDef`,\nbecause an access scenario stages resources across pre-existing cogmaps *and* contexts to probe\nthe gates.)",
      "type": "object",
      "properties": {
        "body": {
          "type": "string"
        },
        "doc_type": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "facets": {
          "anyOf": [
            {
              "$ref": "#/$defs/FacetDef"
            },
            {
              "type": "null"
            }
          ]
        },
        "key": {
          "description": "local stable id — edges/asserts reference this",
          "type": "string"
        },
        "origin_uri": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "key",
        "origin_uri",
        "body"
      ]
    },
    "Seed": {
      "description": "The seed document (`tests/fixtures/seeds/*.yaml`): the shape-of-the-seed a foundational cogmap\nis born from. `name` is the cogmap name `cogmap_genesis` registers.",
      "type": "object",
      "properties": {
        "cogmap": {
          "$ref": "#/$defs/CogmapDef"
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EdgeDef"
          }
        },
        "name": {
          "type": "string"
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResourceDef"
          }
        },
        "uses_lenses": {
          "description": "Names of (system-seeded) lenses this seed's cogmap uses; validated up front.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "world": {
          "$ref": "#/$defs/WorldDef"
        }
      },
      "required": [
        "name",
        "cogmap",
        "world",
        "resources",
        "uses_lenses"
      ]
    },
    "SeedRef": {
      "description": "`seed:` is either a path to a seed document (resolved relative to the scenario file's directory)\nor the seed embedded inline. Untagged: a YAML string is a reference, a map is an embed.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/Seed"
        }
      ]
    },
    "Step": {
      "description": "Internally tagged by `do:` — serde_yaml 0.9 rejects the externally-tagged single-key-map form\n(it wants `!Variant` tags), so the runbook discriminates on a `do` field. Each mutation variant\nmirrors a `SeedAction` (events.rs) 1:1; `materialize`/`assert` drive + check the projection.",
      "oneOf": [
        {
          "description": "Add a concept resource to the map mid-runbook (one content-block body, optional facets). Its\n`key` joins the runner's key map for later steps. Home is always the scenario cogmap.",
          "type": "object",
          "properties": {
            "body": {
              "type": "string"
            },
            "do": {
              "type": "string",
              "const": "create_resource"
            },
            "doc_type": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "facets": {
              "anyOf": [
                {
                  "$ref": "#/$defs/FacetDef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "key": {
              "type": "string"
            },
            "origin_uri": {
              "type": "string"
            },
            "title": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            }
          },
          "required": [
            "do",
            "key",
            "origin_uri",
            "body"
          ]
        },
        {
          "description": "Set a resource's `facet` property (re-facet / re-weight). `resource` is a key.",
          "type": "object",
          "properties": {
            "do": {
              "type": "string",
              "const": "set_facet"
            },
            "resource": {
              "type": "string"
            },
            "values": {
              "type": "object",
              "additionalProperties": true
            },
            "weight": {
              "type": "number",
              "format": "double",
              "default": 1.0
            }
          },
          "required": [
            "do",
            "resource",
            "values"
          ]
        },
        {
          "description": "Assert a typed edge between two keyed resources (replaces the old special-cased `emit_event`).",
          "type": "object",
          "properties": {
            "do": {
              "type": "string",
              "const": "assert_edge"
            },
            "from": {
              "type": "string"
            },
            "kind": {
              "$ref": "#/$defs/EdgeKind"
            },
            "label": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "to": {
              "type": "string"
            },
            "weight": {
              "type": "number",
              "format": "double",
              "default": 1.0
            }
          },
          "required": [
            "do",
            "from",
            "to",
            "kind"
          ]
        },
        {
          "description": "Fold the live edge at `{from,to,kind}` coordinates (retire a relationship). The runner resolves\nthe non-folded edge to its id, then fires `relationship_fold`.",
          "type": "object",
          "properties": {
            "do": {
              "type": "string",
              "const": "fold_edge"
            },
            "from": {
              "type": "string"
            },
            "kind": {
              "$ref": "#/$defs/EdgeKind"
            },
            "reason": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "to": {
              "type": "string"
            }
          },
          "required": [
            "do",
            "from",
            "to",
            "kind"
          ]
        },
        {
          "description": "Revise a concept resource's body prose (a content-only mutation: new chunk embeddings, no edge\nor facet change). Fires `block_mutated` on the resource's single body block. `resource` is a key.",
          "type": "object",
          "properties": {
            "body": {
              "type": "string"
            },
            "do": {
              "type": "string",
              "const": "revise"
            },
            "resource": {
              "type": "string"
            }
          },
          "required": [
            "do",
            "resource",
            "body"
          ]
        },
        {
          "type": "object",
          "properties": {
            "do": {
              "type": "string",
              "const": "materialize"
            },
            "lens": {
              "type": "string"
            }
          },
          "required": [
            "do",
            "lens"
          ]
        },
        {
          "type": "object",
          "properties": {
            "checks": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Expectation"
              }
            },
            "do": {
              "type": "string",
              "const": "assert"
            }
          },
          "required": [
            "do",
            "checks"
          ]
        }
      ]
    },
    "SystemAccess": {
      "description": "The `system_access` PG enum — a profile's platform-wide access tier. Typed\nin the YAML model so an invalid value fails at deserialization rather than at\nthe `$n::system_access` cast after the load transaction opens.",
      "type": "string",
      "enum": [
        "none",
        "approved",
        "admin"
      ]
    },
    "TelosDef": {
      "description": "The telos charter as real content-blocks (domain-B §1, content-block-primitive β): block-0 is the\n`statement`, blocks 1..n are the `questions` (each `question + \"\\n\\n\" + context`), then `framing`\nblocks situate the telos. Each block's kind is stamped as a `block_role` property\n(`statement`/`question`/`framing`) by the persist path — see `block_specs`. The loader\nturns this into an ordered prose list for `content::prepare_blocks`.",
      "type": "object",
      "properties": {
        "framing": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/QuestionDef"
          }
        },
        "statement": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "statement"
      ]
    },
    "WorldDef": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDef"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProfileDef"
          }
        }
      },
      "required": [
        "profiles",
        "entities"
      ]
    }
  }
}
