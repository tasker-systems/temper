  "query": "\n        SELECT v.rt_nonce, v.rt_ciphertext, v.at_nonce, v.at_ciphertext,\n               v.access_expires_at, v.revoked_at, p.is_active\n          FROM kb_slack_grant_vault v\n          JOIN kb_profiles p ON p.id = v.profile_id\n         WHERE v.slack_principal_id = $1\n         FOR UPDATE OF v\n        ",
