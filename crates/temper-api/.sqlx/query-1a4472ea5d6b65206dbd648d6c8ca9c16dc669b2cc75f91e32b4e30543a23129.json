  "query": "UPDATE kb_team_members SET role = $3\n            WHERE team_id = $1 AND profile_id = $2\n              AND NOT (\n                  role = 'owner'\n                  AND (SELECT COUNT(*) FROM kb_team_members\n                         WHERE team_id = $1 AND role = 'owner') = 1\n              )\n        RETURNING team_id, profile_id, role AS \"role: TeamRole\", created",
